{
  "name": "Waveshare ESP32-S3 Touch LCD 3.5 (16MB Flash, 8MB PSRAM)",
  "vendor": "Waveshare",
  "url": "https://www.waveshare.com/esp32-s3-touch-lcd-3.5.htm",

  "build": {
    "core": "esp32",
    "cpu": "esp32s3",
    "f_cpu": "240000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "mcu": "esp32s3",
    "variant": "esp32s3",
    "extra_flags": [
      "-DARDUINO_ESP32S3_DEV",
      "-DBOARD_HAS_PSRAM",
      "-DARDUINO_USB_MODE=1",
      "-DARDUINO_RUNNING_CORE=1",
      "-DARDUINO_EVENT_RUNNING_CORE=1"
    ]
  },

  "connectivity": [
    "wifi",
    "bluetooth"
  ],

  "debug": {
    "openocd_target": "esp32s3.cfg"
  },

  "frameworks": [
    "arduino",
    "espidf"
  ],

  "upload": {
    "flash_size": "16MB",
    "maximum_ram_size": 327680,
    "maximum_size": 16777216,
    "require_upload_port": true,
    "speed": 460800
  }
}